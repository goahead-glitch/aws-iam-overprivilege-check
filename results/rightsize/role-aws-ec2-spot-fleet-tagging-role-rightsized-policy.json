{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Effect": "Allow",
      "Action": [
        "ec2:DescribeImages",
        "ec2:DescribeInstanceStatus",
        "ec2:DescribeSubnets"
      ],
      "Resource": "*",
      "Sid": "(no-sid)"
    },
    {
      "Effect": "Allow",
      "Condition": {
        "StringEquals": {
          "iam:PassedToService": [
            "ec2.amazonaws.com",
            "ec2.amazonaws.com.cn"
          ]
        }
      },
      "Action": [
        "iam:PassRole"
      ],
      "Resource": "*",
      "Sid": "(no-sid)"
    }
  ]
}